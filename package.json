{
  "name": "obsidian-fantasy-map",
  "version": "0.1.0",
  "description": "Display a fantasy campaign map with interactive Features linked to vault notes",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "^20.19.0"
  },
  "main": "./dist/main.js",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -noEmit -skipLibCheck",
    "lint": "eslint",
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/leaflet": "1.9.21",
    "@types/node": "20.19.35",
    "esbuild": "0.27.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "17.4.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "dependencies": {
    "@geoman-io/leaflet-geoman-free": "2.19.2",
